# ClaimPilot configuration — copy to .env and adjust.
# Demonstration system. Synthetic data only. No real secrets here.

# --- Database (matches docker-compose.yml) ---
# SQLAlchemy async URL (asyncpg driver).
DATABASE_URL=postgresql+asyncpg://claimpilot:claimpilot@localhost:5432/claimpilot

# --- LLM / embeddings (OpenAI-compatible) ---
# Default: local gateway / Ollama. No external API key or cost.
#   Run e.g.:  ollama pull nomic-embed-text && ollama pull llama3.1
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama            # Ollama ignores this; any non-empty value works.
LLM_MODEL=llama3.1
EMBED_MODEL=nomic-embed-text
# Embedding dimension MUST match EMBED_MODEL. pgvector columns are fixed-dimension:
# changing this requires re-migrating and re-embedding (see docs/adr/0001, 0002).
#   nomic-embed-text -> 768   |   text-embedding-3-small -> 1536
EMBED_DIM=768

# --- To target OpenAI instead, set: ---
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...            # your key, never commit it
# LLM_MODEL=gpt-4o-mini
# EMBED_MODEL=text-embedding-3-small
# EMBED_DIM=1536

# --- Retrieval ---
RETRIEVAL_TOP_K=5

# --- App ---
LOG_LEVEL=INFO
